@model SportsReserves.DTOs.UserDto
@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-plus me-2" style="color:var(--accent);"></i>Nuevo Usuario</h1>
        <p>Registra un nuevo usuario en el sistema</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
}

<div class="card" style="max-width:560px;">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(0,229,160,.12);color:var(--accent);"><i class="bi bi-person"></i></div>
        Datos del Usuario
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-3">
                <div class="col">
                    <label class="form-label">Nombre completo</label>
                    <input asp-for="Name" class="form-control" placeholder="Ej: Juan Pérez" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:.75rem;"></span>
                </div>
                <div class="col">
                    <label class="form-label">Documento</label>
                    <input asp-for="Document" class="form-control" placeholder="Número de documento" />
                    <span asp-validation-for="Document" class="text-danger" style="font-size:.75rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Teléfono</label>
                <input asp-for="Phone" class="form-control" placeholder="Ej: 3001234567" />
                <span asp-validation-for="Phone" class="text-danger" style="font-size:.75rem;"></span>
            </div>
            <div class="mb-4">
                <label class="form-label">Correo electrónico</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="usuario@email.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:.75rem;"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success flex-grow-1"><i class="bi bi-check-lg me-1"></i> Guardar Usuario</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
