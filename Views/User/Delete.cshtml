@model SportsReserves.Models.User
@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-x me-2" style="color:#f87171;"></i>Eliminar Usuario</h1>
        <p>Confirma la eliminación del usuario</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Volver</a>
</div>

<div class="card delete-card">
    <div class="card-body text-center py-4">
        <div class="delete-icon-wrap mx-auto">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h5 class="mb-1" style="font-weight:700;">¿Confirmar eliminación?</h5>
        <p style="color:#8b949e; font-size:.88rem;">Esta acción no se puede deshacer.</p>

        <div class="card mt-3 mb-4 text-start" style="background:#0d1117;">
            <div class="card-body py-3">
                <div class="d-flex justify-content-between mb-2">
                    <span style="color:#8b949e; font-size:.8rem;">NOMBRE</span>
                    <strong>@Model.Name</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span style="color:#8b949e; font-size:.8rem;">DOCUMENTO</span>
                    <span>@Model.Document</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:#8b949e; font-size:.8rem;">EMAIL</span>
                    <span style="color:#8b949e;">@Model.Email</span>
                </div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger flex-grow-1">
                <i class="bi bi-trash me-1"></i> Sí, eliminar
            </button>
            <a asp-action="Index" class="btn btn-secondary flex-grow-1">Cancelar</a>
        </form>
    </div>
</div>
