@model SportsReserves.DTOs.UserDto
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-gear me-2" style="color:#f59e0b;"></i>Editar Usuario</h1>
        <p>Modifica los datos del usuario seleccionado</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
}

<div class="card" style="max-width:560px;">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(245,158,11,.12);color:#f59e0b;"><i class="bi bi-pencil"></i></div>
        Editar datos del usuario
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div class="row g-3 mb-3">
                <div class="col">
                    <label class="form-label">Nombre completo</label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="col">
                    <label class="form-label">Documento</label>
                    <input asp-for="Document" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Teléfono</label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-4">
                <label class="form-label">Correo electrónico</label>
                <input asp-for="Email" class="form-control" type="email" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning flex-grow-1"><i class="bi bi-check-lg me-1"></i> Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
