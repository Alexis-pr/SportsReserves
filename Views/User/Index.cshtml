@model IEnumerable<SportsReserves.Models.User>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-people me-2" style="color:#f59e0b;"></i>Usuarios</h1>
        <p>Gestión de usuarios registrados en el sistema</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-person-plus me-1"></i> Nuevo Usuario
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]</div>
}

<div class="card">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(245,158,11,.12);color:#f59e0b;"><i class="bi bi-table"></i></div>
        Lista de usuarios
        <span class="ms-auto badge" style="background:rgba(255,255,255,.07);color:#8b949e;font-size:.72rem;padding:4px 10px;border-radius:20px;">
            @Model.Count() registros
        </span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:#484f58;">
                <i class="bi bi-people" style="font-size:2.5rem;"></i>
                <p class="mt-3 mb-0">No hay usuarios registrados</p>
                <a asp-action="Create" class="btn btn-success btn-sm mt-3">Crear primer usuario</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Documento</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td style="color:#484f58; font-size:.78rem;">@user.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:#0d1117;flex-shrink:0;">
                                            @(user.Name?.Length > 0 ? user.Name[0].ToString().ToUpper() : "?")
                                        </div>
                                        <strong>@user.Name</strong>
                                    </div>
                                </td>
                                <td style="font-family:monospace;font-size:.85rem;">@user.Document</td>
                                <td>@user.Phone</td>
                                <td style="color:#8b949e;">@user.Email</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
