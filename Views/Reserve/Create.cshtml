@model SportsReserves.DTOs.ReserveDto
@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-calendar-plus me-2" style="color:var(--accent);"></i>Nueva Reserva</h1>
        <p>Completa los datos para registrar una reserva</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
    </div>
}

<div class="card" style="max-width:600px;">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(0,229,160,.12);color:var(--accent);"><i class="bi bi-calendar-event"></i></div>
        Datos de la Reserva
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select">
                    <option value="">— Seleccionar usuario —</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Deporte</label>
                <select asp-for="SportId" asp-items="ViewBag.Sports" class="form-select">
                    <option value="">— Seleccionar deporte —</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Fecha</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>

            <div class="row g-3 mb-4">
                <div class="col">
                    <label class="form-label">Hora inicio</label>
                    <input asp-for="HourStart" type="time" class="form-control" />
                </div>
                <div class="col">
                    <label class="form-label">Hora fin</label>
                    <input asp-for="HourEnd" type="time" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i> Guardar Reserva
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
