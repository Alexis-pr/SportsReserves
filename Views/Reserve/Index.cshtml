@model IEnumerable<SportsReserves.Models.Reserve>
@{
    ViewData["Title"] = "Reservas";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-calendar-check me-2" style="color:var(--accent);"></i>Reservas</h1>
        <p>Listado completo de reservas deportivas</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i> Nueva Reserva
    </a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Message"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(0,229,160,.12);color:var(--accent);"><i class="bi bi-table"></i></div>
        Todas las reservas
        <span class="ms-auto badge" style="background:rgba(255,255,255,.07);color:#8b949e;font-size:.72rem;padding:4px 10px;border-radius:20px;">
            @Model.Count() registros
        </span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:#484f58;">
                <i class="bi bi-calendar-x" style="font-size:2.5rem;"></i>
                <p class="mt-3 mb-0">No hay reservas registradas</p>
                <a asp-action="Create" class="btn btn-success btn-sm mt-3">Crear primera reserva</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Usuario</th>
                            <th>Deporte</th>
                            <th>Fecha</th>
                            <th>Hora inicio</th>
                            <th>Hora fin</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td style="color:#484f58; font-size:.78rem;">@r.Id</td>
                                <td>
                                    <div style="font-weight:600;">@r.User?.Name</div>
                                </td>
                                <td>
                                    <span style="background:rgba(59,130,246,.12);color:#60a5fa;padding:3px 10px;border-radius:6px;font-size:.78rem;font-weight:600;">
                                        @r.Sport?.TypeSport
                                    </span>
                                </td>
                                <td>@r.Date.ToShortDateString()</td>
                                <td><i class="bi bi-clock me-1" style="color:#484f58;"></i>@r.HourStart</td>
                                <td><i class="bi bi-clock me-1" style="color:#484f58;"></i>@r.HourEnd</td>
                                <td>
                                    @{
                                        var stateClass = r.State?.ToLower() switch {
                                            "confirmada" => "badge-confirmada",
                                            "cancelada"  => "badge-cancelada",
                                            _            => "badge-programada"
                                        };
                                    }
                                    <span class="badge-state @stateClass">@r.State</span>
                                </td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('¿Eliminar esta reserva?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
