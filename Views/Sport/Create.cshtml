@model SportsReserves.DTOs.SportDto
@{
    ViewData["Title"] = "Nuevo Deporte";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-trophy me-2" style="color:#60a5fa;"></i>Nuevo Deporte</h1>
        <p>Registra un nuevo tipo de deporte en el sistema</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
}

<div class="card" style="max-width:480px;">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(59,130,246,.12);color:#60a5fa;"><i class="bi bi-trophy"></i></div>
        Datos del Deporte
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label">Tipo de Deporte</label>
                <input asp-for="TypeSport" class="form-control" placeholder="Ej: Fútbol, Baloncesto..." />
                <span asp-validation-for="TypeSport" class="text-danger" style="font-size:.78rem;"></span>
            </div>
            <div class="mb-4">
                <label class="form-label">Capacidad (personas)</label>
                <input asp-for="Capacity" class="form-control" type="number" min="1" placeholder="Ej: 22" />
                <span asp-validation-for="Capacity" class="text-danger" style="font-size:.78rem;"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-check-lg me-1"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
