@model IEnumerable<SportsReserves.Models.Sport>
@{
    ViewData["Title"] = "Deportes";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-trophy me-2" style="color:#60a5fa;"></i>Deportes</h1>
        <p>Tipos de deporte disponibles en el sistema</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nuevo Deporte
    </a>
</div>

<div class="filter-bar d-flex gap-2 align-items-end">
    <form method="get" asp-action="Index" class="d-flex gap-2 flex-grow-1">
        <div class="flex-grow-1">
            <label class="form-label">Filtrar por tipo</label>
            <input type="text" name="typeSport" class="form-control" placeholder="Ej: Fútbol, Baloncesto..." />
        </div>
        <div class="d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Buscar</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i></a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(59,130,246,.12);color:#60a5fa;"><i class="bi bi-table"></i></div>
        Lista de deportes
        <span class="ms-auto badge" style="background:rgba(255,255,255,.07);color:#8b949e;font-size:.72rem;padding:4px 10px;border-radius:20px;">
            @Model.Count() registros
        </span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:#484f58;">
                <i class="bi bi-trophy" style="font-size:2.5rem;"></i>
                <p class="mt-3 mb-0">No hay deportes registrados</p>
                <a asp-action="Create" class="btn btn-primary btn-sm mt-3">Crear primer deporte</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tipo de Deporte</th>
                            <th>Capacidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="color:#484f58; font-size:.78rem;">@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:8px;height:8px;border-radius:50%;background:var(--accent-2);"></div>
                                        <strong>@item.TypeSport</strong>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-size:.85rem;">
                                        <i class="bi bi-people me-1" style="color:#8b949e;"></i>@item.Capacity personas
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
