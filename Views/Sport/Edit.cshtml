@model SportsReserves.DTOs.SportDto
@{
    ViewData["Title"] = "Editar Deporte";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-pencil-square me-2" style="color:#f59e0b;"></i>Editar Deporte</h1>
        <p>Modifica los datos del deporte seleccionado</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
}

<div class="card" style="max-width:480px;">
    <div class="card-header">
        <div class="header-icon" style="background:rgba(245,158,11,.12);color:#f59e0b;"><i class="bi bi-pencil"></i></div>
        Editar datos
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div class="mb-3">
                <label class="form-label">Tipo de Deporte</label>
                <input asp-for="TypeSport" class="form-control" />
            </div>
            <div class="mb-4">
                <label class="form-label">Capacidad (personas)</label>
                <input asp-for="Capacity" class="form-control" type="number" min="1" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning flex-grow-1"><i class="bi bi-check-lg me-1"></i> Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
