@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1>⚡ Dashboard</h1>
        <p>Sistema de Reservas Deportivas — Panel de control</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-4">
        <a class="stat-card" asp-controller="Reserve" asp-action="Index">
            <div class="stat-icon" style="background:rgba(0,229,160,.12); color:var(--accent);">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div>
                <h4>Reservas</h4>
                <p>Ver y gestionar reservas</p>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a class="stat-card" asp-controller="Sport" asp-action="Index">
            <div class="stat-icon" style="background:rgba(59,130,246,.12); color:#60a5fa;">
                <i class="bi bi-trophy"></i>
            </div>
            <div>
                <h4>Deportes</h4>
                <p>Tipos de deporte y capacidad</p>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a class="stat-card" asp-controller="User" asp-action="Index">
            <div class="stat-icon" style="background:rgba(245,158,11,.12); color:#f59e0b;">
                <i class="bi bi-people"></i>
            </div>
            <div>
                <h4>Usuarios</h4>
                <p>Gestión de usuarios registrados</p>
            </div>
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <div class="header-icon" style="background:rgba(0,229,160,.12); color:var(--accent);"><i class="bi bi-plus-circle"></i></div>
                Acciones rápidas
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-controller="Reserve" asp-action="Create" class="btn btn-success w-100">
                    <i class="bi bi-calendar-plus me-2"></i>Nueva Reserva
                </a>
                <a asp-controller="Sport" asp-action="Create" class="btn btn-primary w-100">
                    <i class="bi bi-trophy me-2"></i>Nuevo Deporte
                </a>
                <a asp-controller="User" asp-action="Create" class="btn btn-secondary w-100">
                    <i class="bi bi-person-plus me-2"></i>Nuevo Usuario
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <div class="header-icon" style="background:rgba(59,130,246,.12); color:#60a5fa;"><i class="bi bi-info-circle"></i></div>
                Acerca del sistema
            </div>
            <div class="card-body">
                <p class="mb-2" style="font-size:.88rem; color:#8b949e;">
                    Plataforma de gestión de reservas para instalaciones deportivas. Administra usuarios, deportes y reservas de forma eficiente.
                </p>
                <hr>
                <div class="d-flex flex-column gap-1" style="font-size:.8rem; color:#8b949e;">
                    <span><i class="bi bi-check-circle text-success me-2"></i>Gestión de reservas con estado</span>
                    <span><i class="bi bi-check-circle text-success me-2"></i>Control de capacidad por deporte</span>
                    <span><i class="bi bi-check-circle text-success me-2"></i>Registro completo de usuarios</span>
                </div>
            </div>
        </div>
    </div>
</div>
